{
  "id": "sample-values",
  "defaultLocale": "en",
  "locales": ["en", "zh"],
  "title": {
    "en": "Citanger Fruit Values Test",
    "zh": "Citanger 水果价值测试"
  },
  "description": {
    "en": "A richer demonstration test showing dot-based bipolar scales, multiple-choice effects, hidden branches, triggered axes, report-hidden axes, medals, multilingual text, and server-side scoring.",
    "zh": "一个更复杂的演示测试，展示点状双极量表、多选项效果、隐藏分支、触发轴、报告隐藏轴、徽章、多语言文本和服务端计分。"
  },
  "axes": [
    {
      "id": "fruit_affinity",
      "defaultEnabled": true,
      "initial": 0,
      "color": "#2F6FA3",
      "hideWhenAxesEnabled": ["sweetness"],
      "name": {
        "en": "Fruit Affinity",
        "zh": "水果偏好"
      },
      "leftLabel": {
        "en": "Avoids fruit",
        "zh": "回避水果"
      },
      "rightLabel": {
        "en": "Enjoys fruit",
        "zh": "喜欢水果"
      }
    },
    {
      "id": "novelty",
      "defaultEnabled": true,
      "initial": 0,
      "name": {
        "en": "Novelty",
        "zh": "新奇偏好"
      },
      "leftLabel": {
        "en": "Familiar",
        "zh": "熟悉"
      },
      "rightLabel": {
        "en": "Experimental",
        "zh": "尝新"
      }
    },
    {
      "id": "sweetness",
      "defaultEnabled": false,
      "initial": 0,
      "opposition": true,
      "colors": {
        "left": "#4E83B8",
        "right": "#C56A52"
      },
      "enabledBy": {
        "any": [
          { "type": "answer", "questionId": "fruit_interest", "answerIds": ["dot_1", "dot_2"] },
          { "type": "value", "axisId": "fruit_affinity", "op": ">=", "value": 2 }
        ]
      },
      "name": {
        "en": "Fruit Sweetness Preference",
        "zh": "水果甜酸偏好"
      },
      "leftLabel": {
        "en": "Sour",
        "zh": "偏酸"
      },
      "rightLabel": {
        "en": "Sweet",
        "zh": "偏甜"
      }
    },
    {
      "id": "texture",
      "defaultEnabled": false,
      "initial": 0,
      "opposition": true,
      "enabledBy": {
        "any": [
          { "type": "answer", "questionId": "basket_picker", "answerIds": ["basket_apple", "basket_banana"] },
          {
            "type": "value",
            "axisId": "fruit_affinity",
            "op": ">=",
            "value": 3,
            "whenNoPendingRelated": true,
            "relatedAxisIds": ["fruit_affinity"]
          }
        ]
      },
      "name": {
        "en": "Texture Preference",
        "zh": "口感偏好"
      },
      "leftLabel": {
        "en": "Crisp",
        "zh": "清脆"
      },
      "rightLabel": {
        "en": "Soft",
        "zh": "柔软"
      }
    },
    {
      "id": "citrus_focus",
      "defaultEnabled": false,
      "initial": 0,
      "enabledBy": {
        "all": [
          {
            "type": "value",
            "axisId": "fruit_affinity",
            "op": ">=",
            "value": 3,
            "whenNoPendingRelated": true,
            "relatedAxisIds": ["fruit_affinity", "sweetness"]
          },
          {
            "type": "value",
            "axisId": "novelty",
            "op": ">=",
            "value": 1
          }
        ]
      },
      "name": {
        "en": "Citrus Focus",
        "zh": "柑橘倾向"
      },
      "leftLabel": {
        "en": "Soft fruit",
        "zh": "柔和水果"
      },
      "rightLabel": {
        "en": "Citrus",
        "zh": "柑橘"
      }
    }
  ],
  "questions": [
    {
      "id": "fruit_interest",
      "type": "scale",
      "axisId": "fruit_affinity",
      "relatedAxes": ["fruit_affinity"],
      "subtitle": {
        "en": "General appetite",
        "zh": "整体兴趣"
      },
      "text": {
        "en": "How much do you like fruit in general?",
        "zh": "整体来说，你有多喜欢水果？"
      },
      "leftLabel": {
        "en": "Avoid",
        "zh": "回避"
      },
      "rightLabel": {
        "en": "Enjoy",
        "zh": "喜欢"
      },
      "scale": {
        "type": "dots",
        "dots": 5,
        "pointsPerDot": 1
      }
    },
    {
      "id": "apple_attitude",
      "type": "scale",
      "axisId": "fruit_affinity",
      "relatedAxes": ["fruit_affinity"],
      "text": {
        "en": "Where do apples land for you?",
        "zh": "苹果对你来说处在什么位置？"
      },
      "leftLabel": {
        "en": "Least favourable",
        "zh": "最不喜欢"
      },
      "rightLabel": {
        "en": "Most favourable",
        "zh": "最喜欢"
      },
      "scale": {
        "type": "dots",
        "dots": 7,
        "pointsPerDot": 1
      }
    },
    {
      "id": "try_new_food",
      "type": "scale",
      "axisId": "novelty",
      "relatedAxes": ["novelty"],
      "subtitle": {
        "en": "Habit versus exploration",
        "zh": "习惯与探索"
      },
      "text": {
        "en": "When choosing fruit, do you prefer familiar picks or new discoveries?",
        "zh": "选择水果时，你更喜欢熟悉选择还是新发现？"
      },
      "leftLabel": {
        "en": "Familiar",
        "zh": "熟悉"
      },
      "rightLabel": {
        "en": "New discoveries",
        "zh": "新发现"
      },
      "scale": {
        "type": "dots",
        "dots": 5,
        "pointsPerDot": 1
      }
    },
    {
      "id": "basket_picker",
      "type": "choice",
      "multiSelect": true,
      "minSelections": 1,
      "maxSelections": 2,
      "relatedAxes": ["fruit_affinity", "novelty", "texture", "citrus_focus"],
      "subtitle": {
        "en": "Always-shown multi-select demo",
        "zh": "始终显示的多选示例"
      },
      "text": {
        "en": "Build a quick fruit basket: choose up to 2 fruits.",
        "zh": "先搭一个快速果篮：请选择最多 2 种水果。"
      },
      "options": [
        {
          "id": "basket_apple",
          "label": { "en": "Apple", "zh": "苹果" },
          "effects": [
            { "axisId": "fruit_affinity", "value": 1 },
            { "axisId": "novelty", "value": -1 },
            { "axisId": "texture", "value": -1 }
          ]
        },
        {
          "id": "basket_orange",
          "label": { "en": "Orange", "zh": "橙子" },
          "effects": [
            { "axisId": "fruit_affinity", "value": 1 },
            { "axisId": "novelty", "value": 1 },
            { "axisId": "citrus_focus", "value": 1 }
          ]
        },
        {
          "id": "basket_banana",
          "label": { "en": "Banana", "zh": "香蕉" },
          "effects": [
            { "axisId": "fruit_affinity", "value": 1 },
            { "axisId": "texture", "value": 1 }
          ]
        },
        {
          "id": "basket_dragonfruit",
          "label": { "en": "Dragon fruit", "zh": "火龙果" },
          "effects": [
            { "axisId": "novelty", "value": 2 }
          ]
        }
      ]
    },
    {
      "id": "fruit_moment",
      "type": "choice",
      "relatedAxes": ["fruit_affinity", "novelty"],
      "subtitle": {
        "en": "Single-select demo",
        "zh": "单选示例"
      },
      "text": {
        "en": "When are you most likely to eat fruit?",
        "zh": "你最可能在什么时候吃水果？"
      },
      "options": [
        {
          "id": "morning",
          "label": { "en": "Morning", "zh": "早上" },
          "effects": [
            { "axisId": "fruit_affinity", "value": 1 }
          ]
        },
        {
          "id": "afternoon",
          "label": { "en": "Afternoon", "zh": "下午" },
          "effects": [
            { "axisId": "fruit_affinity", "value": 1 },
            { "axisId": "novelty", "value": 1 }
          ]
        },
        {
          "id": "night",
          "label": { "en": "Night", "zh": "晚上" },
          "effects": [
            { "axisId": "novelty", "value": -1 }
          ]
        }
      ]
    },
    {
      "id": "sweet_or_sour",
      "type": "scale",
      "axisId": "sweetness",
      "relatedAxes": ["sweetness"],
      "enabledBy": {
        "any": [
          { "type": "answer", "questionId": "fruit_interest", "answerIds": ["dot_1", "dot_2"] },
          { "type": "value", "axisId": "fruit_affinity", "op": ">=", "value": 2 }
        ]
      },
      "subtitle": {
        "en": "Triggered flavor branch",
        "zh": "触发后的风味分支"
      },
      "text": {
        "en": "Do you prefer a sour edge or a sweet finish?",
        "zh": "你更喜欢酸爽边缘还是甜美收尾？"
      },
      "leftLabel": {
        "en": "Sour",
        "zh": "偏酸"
      },
      "rightLabel": {
        "en": "Sweet",
        "zh": "偏甜"
      },
      "scale": {
        "type": "dots",
        "dots": 7,
        "pointsPerDot": 1
      }
    },
    {
      "id": "dessert_context",
      "type": "choice",
      "relatedAxes": ["sweetness", "novelty"],
      "enabledBy": {
        "any": [
          { "type": "answer", "questionId": "fruit_interest", "answerIds": ["dot_1", "dot_2"] },
          { "type": "value", "axisId": "fruit_affinity", "op": ">=", "value": 2 }
        ]
      },
      "text": {
        "en": "How would you rather use fruit?",
        "zh": "你更想怎样使用水果？"
      },
      "options": [
        {
          "id": "fresh",
          "label": { "en": "Fresh snack", "zh": "新鲜零食" },
          "effects": [
            { "axisId": "sweetness", "value": -1 },
            { "axisId": "novelty", "value": -1 }
          ]
        },
        {
          "id": "dessert",
          "label": { "en": "Dessert", "zh": "甜点" },
          "effects": [
            { "axisId": "sweetness", "value": 2 }
          ]
        },
        {
          "id": "drink",
          "label": { "en": "Drink or mocktail", "zh": "饮品或无酒精鸡尾酒" },
          "effects": [
            { "axisId": "novelty", "value": 1 },
            { "axisId": "citrus_focus", "value": 1 }
          ]
        }
      ]
    },
    {
      "id": "texture_preference",
      "type": "scale",
      "axisId": "texture",
      "relatedAxes": ["texture"],
      "subtitle": {
        "en": "Three-dot texture branch",
        "zh": "三点口感分支"
      },
      "enabledBy": {
        "any": [
          { "type": "answer", "questionId": "basket_picker", "answerIds": ["basket_apple", "basket_banana"] },
          {
            "type": "value",
            "axisId": "fruit_affinity",
            "op": ">=",
            "value": 3,
            "whenNoPendingRelated": true,
            "relatedAxisIds": ["fruit_affinity"]
          }
        ]
      },
      "text": {
        "en": "Which texture feels more satisfying?",
        "zh": "哪种口感更让你满足？"
      },
      "leftLabel": {
        "en": "Crisp",
        "zh": "清脆"
      },
      "rightLabel": {
        "en": "Soft",
        "zh": "柔软"
      },
      "scale": {
        "type": "dots",
        "dots": 3,
        "pointsPerDot": 2
      }
    },
    {
      "id": "citrus_branch",
      "type": "choice",
      "relatedAxes": ["citrus_focus"],
      "enabledBy": {
        "all": [
          {
            "type": "value",
            "axisId": "fruit_affinity",
            "op": ">=",
            "value": 3,
            "whenNoPendingRelated": true,
            "relatedAxisIds": ["fruit_affinity", "sweetness"]
          },
          {
            "type": "value",
            "axisId": "novelty",
            "op": ">=",
            "value": 1
          }
        ]
      },
      "subtitle": {
        "en": "Deferred trigger demo",
        "zh": "延迟触发示例"
      },
      "text": {
        "en": "Your base fruit questions are done. Which sharper profile sounds best now?",
        "zh": "基础水果题已完成。现在你更偏好哪种鲜明风味？"
      },
      "options": [
        {
          "id": "lemon",
          "label": { "en": "Lemon", "zh": "柠檬" },
          "effects": [{ "axisId": "citrus_focus", "value": 2 }]
        },
        {
          "id": "orange",
          "label": { "en": "Orange", "zh": "橙子" },
          "effects": [{ "axisId": "citrus_focus", "value": 1 }]
        },
        {
          "id": "peach",
          "label": { "en": "Peach", "zh": "桃子" },
          "effects": [{ "axisId": "citrus_focus", "value": -1 }]
        }
      ]
    }
  ],
  "finalResult": {
    "if": { "axisId": "fruit_affinity", "metric": "percent", "op": ">=", "value": 70 },
    "then": {
      "if": { "axisId": "sweetness", "metric": "percent", "op": ">=", "value": 65 },
      "then": {
        "id": "sweet_fruit_enthusiast",
        "title": {
          "en": "Sweet Fruit Enthusiast",
          "zh": "甜味水果爱好者"
        },
        "description": {
          "en": "You like fruit strongly and tend to prefer a sweeter finish.",
          "zh": "你非常喜欢水果，并倾向于更甜的收尾。"
        }
      },
      "else": {
        "if": { "axisId": "sweetness", "metric": "score", "op": "<", "value": 0 },
        "then": {
          "id": "bright_sour_fruit_fan",
          "title": {
            "en": "Bright Sour Fruit Fan",
            "zh": "酸爽水果派"
          },
          "description": {
            "en": "You like fruit strongly, but sharper and sourer flavors stand out most.",
            "zh": "你非常喜欢水果，但更突出的偏好是鲜明和偏酸的风味。"
          }
        },
        "else": {
          "id": "balanced_fruit_lover",
          "title": {
            "en": "Balanced Fruit Lover",
            "zh": "平衡型水果爱好者"
          },
          "description": {
            "en": "You like fruit and keep a fairly balanced taste profile.",
            "zh": "你喜欢水果，并保持相当平衡的风味偏好。"
          }
        }
      }
    },
    "else": {
      "if": { "axisId": "novelty", "metric": "percent", "op": ">=", "value": 60 },
      "then": {
        "id": "curious_sampler",
        "title": {
          "en": "Curious Sampler",
          "zh": "好奇尝鲜者"
        },
        "description": {
          "en": "Fruit is not your strongest preference, but unusual picks can still catch your attention.",
          "zh": "水果不是你最强的偏好，但少见选择仍然能吸引你的注意。"
        }
      },
      "else": {
        "id": "selective_minimalist",
        "title": {
          "en": "Selective Minimalist",
          "zh": "谨慎选择者"
        },
        "description": {
          "en": "You are selective about fruit and tend to stay with familiar or limited choices.",
          "zh": "你对水果比较挑选，通常停留在熟悉或有限的选择中。"
        }
      }
    }
  },
  "medals": [
    {
      "id": "fruit_devotee",
      "icon": "F",
      "title": {
        "en": "Fruit Devotee",
        "zh": "水果爱好者"
      },
      "description": {
        "en": "You strongly liked fruit and reached a high fruit score.",
        "zh": "你强烈喜欢水果，并获得了较高的水果分。"
      },
      "requirements": {
        "all": [
          { "type": "answer", "questionId": "fruit_interest", "answerId": "dot_2" },
          { "type": "value", "axisId": "fruit_affinity", "op": ">=", "value": 4 }
        ]
      }
    },
    {
      "id": "sour_specialist",
      "icon": "S",
      "title": {
        "en": "Sour Specialist",
        "zh": "酸味专家"
      },
      "description": {
        "en": "You opened the fruit branch and leaned clearly sour.",
        "zh": "你开启了水果分支，并明显偏向酸味。"
      },
      "requirements": {
        "all": [
          { "type": "answer", "questionId": "fruit_interest", "answerIds": ["dot_1", "dot_2"] },
          { "type": "value", "axisId": "sweetness", "op": "<=", "value": -2 }
        ]
      }
    },
    {
      "id": "basket_blender",
      "icon": "B",
      "title": {
        "en": "Basket Blender",
        "zh": "果篮混搭者"
      },
      "description": {
        "en": "Your always-visible multi-select picks show a mixed and exploratory basket.",
        "zh": "你在始终可见的多选题中做出了更混搭、更探索的果篮选择。"
      },
      "requirements": {
        "all": [
          { "type": "answer", "questionId": "basket_picker", "answerIds": ["basket_orange", "basket_dragonfruit"] },
          { "type": "value", "axisId": "novelty", "op": ">=", "value": 1 }
        ]
      }
    },
    {
      "id": "dessert_builder",
      "icon": "D",
      "title": {
        "en": "Dessert Builder",
        "zh": "甜点搭配者"
      },
      "description": {
        "en": "You chose dessert and leaned sweet.",
        "zh": "你选择了甜点，并偏向甜味。"
      },
      "requirements": {
        "all": [
          { "type": "answer", "questionId": "dessert_context", "answerId": "dessert" },
          { "type": "value", "axisId": "sweetness", "op": ">=", "value": 2 }
        ]
      }
    },
    {
      "id": "texture_judge",
      "icon": "T",
      "title": {
        "en": "Texture Judge",
        "zh": "口感评判者"
      },
      "description": {
        "en": "Your branch opened a texture axis and you made a clear texture choice.",
        "zh": "你的分支开启了口感轴，并做出了明确的口感选择。"
      },
      "requirements": {
        "all": [
          { "type": "answer", "questionId": "texture_preference", "answerIds": ["dot_-1", "dot_1"] },
          { "type": "value", "axisId": "fruit_affinity", "op": ">=", "value": 1 }
        ]
      }
    },
    {
      "id": "citrus_explorer",
      "icon": "C",
      "title": {
        "en": "Citrus Explorer",
        "zh": "柑橘探索者"
      },
      "description": {
        "en": "Your triggered branch and final answer both leaned citrus.",
        "zh": "你的触发分支和最终选择都偏向柑橘。"
      },
      "requirements": {
        "all": [
          { "type": "answer", "questionId": "citrus_branch", "answerIds": ["lemon", "orange"] },
          { "type": "value", "axisId": "citrus_focus", "op": ">=", "value": 1 }
        ]
      }
    }
  ]
}
